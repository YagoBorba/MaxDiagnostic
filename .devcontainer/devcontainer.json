{
    "name": "MaxDiagnostic",
    "build": {
        "dockerfile": "Dockerfile",
        "args": { "FLUTTER_VERSION": "3.19.6" }
    },
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/MaxDiagnostic,type=bind,consistency=cached",
    "workspaceFolder": "/workspaces/MaxDiagnostic",
    "postCreateCommand": "flutter doctor",
    "customizations": {
        "vscode": {
            "settings": { "dart.flutterSdkPath": "/opt/flutter" },
            "extensions": [ "Dart-Code.dart-code", "Dart-Code.flutter" ]
        }
    },
    "remoteUser": "vscode"
}